{
  "name": "kgb-sound-system-85",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c cyan,yellow \"node server/index.js\" \"npm --prefix client run dev\"",
    "dev:server": "node server/index.js",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "build-win": "npm --prefix client run build-win",
    "start": "npm --prefix client run start",
    "lint": "npm --prefix client run lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "socket.io": "^4.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "vitest": "^4.1.10"
  }
}
